# Dev defaults match docker-compose.yml: user=school password=school
DATABASE_URL=postgresql://<db-user>:<db-password>@localhost:5433/school_gradebook
JWT_SECRET=change-me-to-a-long-random-string-in-development
API_PORT=3001

# Certificate storage (apps/api): default in-memory in dev — set STORAGE_BACKEND=s3 + MinIO for persistence
# See apps/api/.env.example

# Optional MinIO (docker compose up -d) — only if STORAGE_BACKEND=s3 in apps/api/.env
