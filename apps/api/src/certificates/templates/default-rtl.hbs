<!DOCTYPE html>

<html lang="he" dir="rtl">

<head>

  <meta charset="utf-8" />

  <style>

    body {

      font-family: Arial, Helvetica, sans-serif;

      margin: 2rem;

      color: #1e293b;

    }

    {{#if certificatePrefs.nikud}}
    body { font-family: 'Noto Serif Hebrew', 'Noto Sans Hebrew', Arial, sans-serif; line-height: 2.2; }
    td, th { line-height: 2.2; }
    {{/if}}

    h1 { font-size: 1.4rem; margin-bottom: 0.25rem; }

    h2 { font-size: 1.1rem; font-weight: normal; color: #475569; margin-top: 0; }

    h3 { font-size: 1rem; margin: 0.65rem 0 0.35rem; }

    .meta { margin: 1.5rem 0; line-height: 1.6; }

    table { width: 100%; border-collapse: collapse; margin-top: 0.75rem; }

    th, td { border: 1px solid #cbd5e1; padding: 0.5rem 0.75rem; text-align: right; }

    th { background: #f1f5f9; }

    .footer { margin-top: 2rem; font-size: 0.85rem; color: #64748b; }

    .signatures {

      display: flex;

      justify-content: space-between;

      gap: 2rem;

      margin-top: 2.5rem;

    }

    .signatures-handwritten div {

      flex: 1;

      border-top: 1px solid #94a3b8;

      padding-top: 0.35rem;

      font-size: 0.85rem;

      color: #475569;

      min-height: 1.5rem;

    }

    .signatures-computer div {

      flex: 1;

      border: 1px solid #cbd5e1;

      padding: 0.5rem;

      font-size: 0.85rem;

      color: #475569;

      min-height: 2.5rem;

    }

    .attendance td:first-child { width: 40%; font-weight: 600; }

    .comment-box {

      border: 1px solid #cbd5e1;

      padding: 0.75rem 1rem;

      min-height: 3rem;

      margin-top: 0.5rem;

      white-space: pre-wrap;

      word-wrap: break-word;

      overflow-wrap: break-word;

      line-height: 1.45;

    }

    .handwritten-cell {
      display: inline-block;
      min-width: 6rem;
      border-bottom: 1px solid #334155;
      min-height: 1.15em;
      vertical-align: bottom;
    }

    .handwritten-lines {
      display: flex;
      flex-direction: column;
      gap: 0.55em;
      margin-top: 0.35rem;
    }

    .handwritten-line {
      width: 100%;
      border-bottom: 1px solid #334155;
      min-height: 1.35em;
    }

    .section-bordered {
      border: 1px solid #64748b;
      border-radius: 4px;
      padding: 0.5rem 0.65rem;
    }

  </style>

</head>

<body>

  <div style="text-align:right;font-size:0.8rem;color:#475569;line-height:1.3;margin-bottom:0.35rem;">
    <div>{{labels.besiata}}</div>
    {{#if certificatePrefs.showProfileNameOnCertificate}}
    {{#if certificateProfileName}}
    <div style="font-size:0.95rem;margin-top:0;">{{certificateProfileName}}</div>
    {{/if}}
    {{/if}}
  </div>

  <h2 style="text-align:center;margin-top:0;">{{labels.title}}</h2>

  <div class="meta" dir="rtl" style="display:flex;flex-wrap:nowrap;align-items:flex-end;gap:1rem;margin:1rem 0;line-height:1.6;">

    <span style="display:inline-flex;align-items:flex-end;gap:0.25rem;flex:1;min-width:0;">
      <strong>{{labels.studentNameLabel}}</strong>
      {{#if fill.studentNameHandwritten}}<span class="handwritten-cell"></span>{{else}}{{student.fullName}}{{/if}}
    </span>

    <span style="display:inline-flex;align-items:flex-end;gap:0.25rem;flex:1;min-width:0;">
      <strong>{{labels.classLabel}}</strong>
      {{#if fill.classNameHandwritten}}<span class="handwritten-cell"></span>{{else}}{{class.name}}{{/if}}
    </span>

    <span style="display:inline-flex;align-items:flex-end;gap:0.25rem;flex:1;min-width:0;">
      <strong>{{labels.termLabel}}</strong>
      {{#if fill.termNameHandwritten}}<span class="handwritten-cell"></span>{{else}}{{term.name}}{{/if}}
    </span>

    <span style="display:inline-flex;align-items:flex-end;gap:0.25rem;flex:1;min-width:0;">
      <strong>{{labels.cohortLabel}}</strong>
      {{#if fill.classYearHebrewHandwritten}}<span class="handwritten-cell"></span>{{else}}{{#if class.cohort}}{{class.cohort}}{{else}}{{class.yearHebrew}}{{/if}}{{/if}}
    </span>

  </div>



  <h3 style="margin-top:0.65rem;">{{labels.gradesSection}}</h3>

  {{#if subjectCategories}}

  {{#each subjectCategories}}

  <h3>{{categoryLabel}}</h3>

  {{#if subCategories}}
  {{#each subCategories}}
  <h4 style="font-size:0.95rem;margin:1rem 0 0.35rem;color:#475569">{{subCategoryLabel}}</h4>
  <table>
    <thead>
      <tr>
        <th>{{@root.labels.subject}}</th>
        <th>{{@root.labels.grade}}</th>
        {{#if ../showComment}}
        <th>{{@root.labels.comment}}</th>
        {{/if}}
      </tr>
    </thead>
    <tbody>
      {{#each subjects}}
      <tr>
        <td>{{subjectName}}</td>
        <td>
          {{#if ../../../fill.gradesHandwritten}}
          <span class="handwritten-cell"></span>
          {{else}}
          {{#if value}}{{value}}{{else}}—{{/if}}
          {{/if}}
        </td>
        {{#if ../../showComment}}
        <td>
          {{#if ../../../fill.gradeCommentsHandwritten}}
          <span class="handwritten-cell"></span>
          {{else}}
          {{#if comment}}{{comment}}{{else}}—{{/if}}
          {{/if}}
        </td>
        {{/if}}
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/each}}
  {{/if}}

  {{#each subjects}}
  {{#if @first}}
  <table>
    <thead>
      <tr>
        <th>{{@root.labels.subject}}</th>
        <th>{{@root.labels.grade}}</th>
        {{#if ../showComment}}
        <th>{{@root.labels.comment}}</th>
        {{/if}}
      </tr>
    </thead>
    <tbody>
  {{/if}}
      <tr>
        <td>{{subjectName}}</td>
        <td>
          {{#if ../../fill.gradesHandwritten}}
          <span class="handwritten-cell"></span>
          {{else}}
          {{#if value}}{{value}}{{else}}—{{/if}}
          {{/if}}
        </td>
        {{#if ../showComment}}
        <td>
          {{#if ../../fill.gradeCommentsHandwritten}}
          <span class="handwritten-cell"></span>
          {{else}}
          {{#if comment}}{{comment}}{{else}}—{{/if}}
          {{/if}}
        </td>
        {{/if}}
      </tr>
  {{#if @last}}
    </tbody>
  </table>
  {{/if}}
  {{/each}}

  {{/each}}

  {{else}}

  <table>

    <thead>

      <tr>

        <th>{{labels.subject}}</th>

        <th>{{labels.grade}}</th>

        {{#if showAnyGradeComment}}

        <th>{{@root.labels.comment}}</th>

        {{/if}}

      </tr>

    </thead>

    <tbody>

      {{#each subjects}}

      <tr>

        <td>{{subjectName}}</td>

        <td>

          {{#if ../fill.gradesHandwritten}}

          <span class="handwritten-cell"></span>

          {{else}}

          {{#if value}}{{value}}{{else}}—{{/if}}

          {{/if}}

        </td>

        {{#if showComment}}

        <td>

          {{#if ../fill.gradeCommentsHandwritten}}

          <span class="handwritten-cell"></span>

          {{else}}

          {{#if comment}}{{comment}}{{else}}—{{/if}}

          {{/if}}

        </td>

        {{/if}}

      </tr>

      {{/each}}

    </tbody>

  </table>

  {{/if}}



  {{#if attendance}}

  <h3>{{labels.attendance}}</h3>

  <table class="attendance{{#if certificatePrefs.attendanceBorder}} section-bordered{{/if}}">

    <tbody>

      {{#if certificatePrefs.absences}}

      <tr>

        <td>{{labels.absences}}</td>

        <td>

          {{#if fill.attendanceHandwritten}}<span class="handwritten-cell"></span>{{else}}{{#if attendance.absences}}{{attendance.absences}}{{else}}—{{/if}}{{/if}}

        </td>

      </tr>

      {{/if}}

      {{#if certificatePrefs.lateness}}

      <tr>

        <td>{{labels.lateness}}</td>

        <td>

          {{#if fill.attendanceHandwritten}}<span class="handwritten-cell"></span>{{else}}{{#if attendance.lateness}}{{attendance.lateness}}{{else}}—{{/if}}{{/if}}

        </td>

      </tr>

      {{/if}}

      {{#if certificatePrefs.hourAbsences}}

      <tr>

        <td>{{labels.hourAbsences}}</td>

        <td>

          {{#if fill.attendanceHandwritten}}<span class="handwritten-cell"></span>{{else}}{{#if attendance.hourAbsences}}{{attendance.hourAbsences}}{{else}}—{{/if}}{{/if}}

        </td>

      </tr>

      {{/if}}

      {{#if certificatePrefs.hourLateness}}

      <tr>

        <td>{{labels.hourLateness}}</td>

        <td>

          {{#if fill.attendanceHandwritten}}<span class="handwritten-cell"></span>{{else}}{{#if attendance.hourLateness}}{{attendance.hourLateness}}{{else}}—{{/if}}{{/if}}

        </td>

      </tr>

      {{/if}}

    </tbody>

  </table>

  {{/if}}



  {{#if certificatePrefs.evaluation}}

  <h3 style="text-align:center;margin:0.65rem 0 0.35rem;">{{labels.evaluation}}</h3>

  <div class="comment-box{{#if certificatePrefs.evaluationBorder}} section-bordered{{/if}}" style="text-align:center;">

    {{#if fill.evaluationHandwritten}}
    <div class="handwritten-lines">
      <div class="handwritten-line"></div>
      <div class="handwritten-line"></div>
      <div class="handwritten-line"></div>
    </div>
    {{else}}
    {{#if evaluation}}{{evaluation}}{{else}}—{{/if}}
    {{/if}}

  </div>

  {{/if}}



  {{#if certificatePrefs.signatures}}

  <div class="signatures {{#if fill.signaturesHandwritten}}signatures-handwritten{{else}}signatures-computer{{/if}}{{#if certificatePrefs.signaturesBorder}} section-bordered{{/if}}" dir="rtl" style="{{#if certificatePrefs.signaturesBorder}}padding:0.5rem 0.65rem;{{/if}}">

    {{#if fill.signaturesHandwritten}}

    {{#if certificatePrefs.signatureHomeroom}}<div>{{labels.homeroomSig}}</div>{{/if}}

    {{#if certificatePrefs.signaturePrincipal}}<div>{{labels.principalSig}}</div>{{/if}}

    {{#if certificatePrefs.signatureParent}}<div>{{labels.parentSig}}</div>{{/if}}

    {{#if displayDate}}<div>{{labels.date}}</div>{{/if}}

    {{else}}

    {{#if certificatePrefs.signatureHomeroom}}
    <div>
      {{#if signatures.homeroom}}{{signatures.homeroom}}{{/if}}
      <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">{{labels.homeroomSig}}</div>
    </div>
    {{/if}}

    {{#if certificatePrefs.signaturePrincipal}}
    <div>
      {{#if signatures.principal}}{{signatures.principal}}{{/if}}
      <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">{{labels.principalSig}}</div>
    </div>
    {{/if}}

    {{#if certificatePrefs.signatureParent}}
    <div>
      {{#if signatures.parent}}{{signatures.parent}}{{/if}}
      <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">{{labels.parentSig}}</div>
    </div>
    {{/if}}

    {{#if displayDate}}
    <div>
      {{#unless fill.dateHandwritten}}{{displayDate}}{{/unless}}
      <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">{{labels.date}}</div>
    </div>
    {{/if}}

    {{/if}}

  </div>

  {{else if displayDate}}

  <div class="signatures {{#if fill.dateHandwritten}}signatures-handwritten{{else}}signatures-computer{{/if}}" dir="rtl">
    {{#if fill.dateHandwritten}}
    <div>{{labels.date}}</div>
    {{else}}
    <div>
      {{displayDate}}
      <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">{{labels.date}}</div>
    </div>
    {{/if}}
  </div>

  {{/if}}



  <div class="footer">{{labels.generatedAt}} {{generatedAt}}</div>

</body>

</html>


