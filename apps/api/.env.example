DATABASE_URL=postgresql://<db-user>:<db-password>@localhost:5433/school_gradebook
JWT_SECRET=change-me-to-a-long-random-string-in-development
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Default: in-memory PDF storage (works without MinIO). For MinIO set STORAGE_BACKEND=s3 and uncomment S3_* below.
STORAGE_BACKEND=memory

# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=certificates
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true

# Super admin bootstrap — used by `prisma db seed` when SEED_DEMO is not set
PLATFORM_ADMIN_EMAIL=superadmin@your-domain.com
PLATFORM_ADMIN_PASSWORD=change-me-to-a-strong-password

# Email (Resend) — get API key from resend.com
RESEND_API_KEY=re_your_key_here
RESEND_FROM=onboarding@resend.dev
# Dev override: send all emails to this address instead of actual recipients
# EMAIL_OVERRIDE=your@email.com
